{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    },
    {
      "source": "/:categorySlug((?!kategorije|brendovi|kolekcije|proizvod|prodavnice|akcija|editorial|admin|api|_next|fonts|images|CDN).*)",
      "destination": "/kategorije/:categorySlug",
      "statusCode": 308,
      "regex": "^(?!/_next)(?:/((?!kategorije|brendovi|kolekcije|proizvod|prodavnice|akcija|editorial|admin|api|_next|fonts|images|CDN).*))(?:/)?$"
    }
  ],
  "headers": [
    {
      "source": "/_next/static/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ],
      "regex": "^/_next/static(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))?(?:/)?$"
    },
    {
      "source": "/fonts/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ],
      "regex": "^/fonts(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))?(?:/)?$"
    },
    {
      "source": "/images/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ],
      "regex": "^/images(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))?(?:/)?$"
    }
  ],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/akcija/[categorySlug]",
      "regex": "^/akcija/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPcategorySlug": "nxtPcategorySlug"
      },
      "namedRegex": "^/akcija/(?<nxtPcategorySlug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/brendovi/[slug]",
      "regex": "^/brendovi/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/brendovi/(?<nxtPslug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/editorial/[slug]",
      "regex": "^/editorial/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/editorial/(?<nxtPslug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/kategorija/[slug]",
      "regex": "^/kategorija/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/kategorija/(?<nxtPslug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/kolekcije/[slug]",
      "regex": "^/kolekcije/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/kolekcije/(?<nxtPslug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/porudzbina/[orderNumber]",
      "regex": "^/porudzbina/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPorderNumber": "nxtPorderNumber"
      },
      "namedRegex": "^/porudzbina/(?<nxtPorderNumber>[^/]+?)(?:/)?$"
    },
    {
      "page": "/prodavnice/[slug]",
      "regex": "^/prodavnice/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/prodavnice/(?<nxtPslug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/proizvod/[slug]",
      "regex": "^/proizvod/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/proizvod/(?<nxtPslug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/[categorySlug]",
      "regex": "^/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPcategorySlug": "nxtPcategorySlug"
      },
      "namedRegex": "^/(?<nxtPcategorySlug>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
